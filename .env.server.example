# 服务器部署环境变量示例，复制为 .env.server 后即可用于 docker-compose.server.yml。
# 容器内默认时区，建议与服务器所在地保持一致。
APP_TZ=Asia/Shanghai

# 服务器访问入口。
# 这里的 SERVER_HOST 只提供给浏览器、回调地址和宿主机暴露端口使用；
# compose 内部服务之间会固定使用 code-processing / hindsight / postgres 等服务名互联。
# 前端默认会使用“当前访问主机名 + VITE_API_PORT”直连后端；
# 如果需要覆盖为完整地址，可直接设置 VITE_API_BASE_URL。
SERVER_HOST=192.168.110.23
FRONTEND_PORT=5173
BACKEND_PORT=8080
VITE_API_BASE_URL=
VITE_API_PORT=8080

# PostgreSQL 数据库配置。
# Docker 内置库默认用 postgres；外部库场景改成服务器可达的 IP/域名，POSTGRES_PORT 填该地址的可达端口。
POSTGRES_HOST=postgres
POSTGRES_DB=ai_agent_platform
POSTGRES_USER=aiclub
POSTGRES_PASSWORD=aiclub123
POSTGRES_PORT=5432
POSTGRES_DATA_DIR=/data/git-ai-club/postgres

# 基础服务端口配置。
CODE_PROCESSING_IP=127.0.0.1
CODE_PROCESSING_PORT=9000
MINIO_PORT=19000
MINIO_CONSOLE_PORT=19001
MINIO_DATA_DIR=/data/git-ai-club/minio
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=
REDIS_DATA_DIR=/data/git-ai-club/redis
HERMES_PORT=18080
HERMES_DATA_DIR=/data/git-ai-club/hermes
HINDSIGHT_PORT=18888
HINDSIGHT_CONSOLE_PORT=19999

# AI Club Pipeline 内置 Woodpecker provider。默认启用；如需临时关闭，可显式改为 false。
WOODPECKER_ENABLED=true
WOODPECKER_PORT=18000
WOODPECKER_DATA_DIR=/data/git-ai-club/woodpecker
WOODPECKER_AGENT_DATA_DIR=/data/git-ai-club/woodpecker-agent
WOODPECKER_AGENT_SECRET=change-me-woodpecker-agent-secret
WOODPECKER_LOG_LEVEL=info
WOODPECKER_HOST=http://192.168.110.23:18000
# 后端在 Docker 网络内走 woodpecker-server，浏览器入口走服务器暴露端口。
# Woodpecker 的 forge / GitLab 接入由执行底座自身维护，不再作为 AI Club 环境变量暴露。
PLATFORM_WOODPECKER_INTERNAL_BASE_URL=http://woodpecker-server:8000
PLATFORM_WOODPECKER_PUBLIC_BASE_URL=http://192.168.110.23:18000
PLATFORM_WOODPECKER_API_TOKEN=
PLATFORM_WOODPECKER_TIMEOUT_SECONDS=20

# GitNexus 本地 Web UI。code-processing 会继续按需启动 gitnexus serve，UI 通过 5174 访问。
PLATFORM_GITNEXUS_ENABLED=true
PLATFORM_GITNEXUS_UI_PUBLIC_PORT=5174
PLATFORM_GITNEXUS_SERVE_PUBLIC_PORT=4747
# GitNexus Nexus AI 统一配置。默认通过 gitnexus-web 同源代理复用 HERMES_LLM_*。
# 如果需要让 GitNexus 使用单独模型，可填写 GITNEXUS_AI_BASE_URL / API_KEY / MODEL 覆盖。
GITNEXUS_AI_AUTO_CONFIG_ENABLED=true
GITNEXUS_AI_PROXY_ENABLED=true
GITNEXUS_AI_FALLBACK_TO_HERMES=true
GITNEXUS_AI_FORCE_CHINESE=true
GITNEXUS_AI_SYSTEM_PROMPT=你是 GitNexus 的代码理解助手。最终回答必须使用简体中文；表格标题、总结、步骤说明和结论都使用中文。代码符号、文件路径、类名、方法名和错误信息保持原文。
GITNEXUS_AI_FORCE_CONFIG=false
GITNEXUS_AI_PROVIDER=
GITNEXUS_AI_BASE_URL=
GITNEXUS_AI_API_KEY=
GITNEXUS_AI_MODEL=
GITNEXUS_AI_TEMPERATURE=0.1
GITNEXUS_AI_MAX_TOKENS=
GITNEXUS_AI_AZURE_ENDPOINT=
GITNEXUS_AI_AZURE_DEPLOYMENT=
GITNEXUS_AI_AZURE_API_VERSION=

# GitLab / Gitee / PR 评审等外部集成配置。
# 以下纳管项优先在“系统设置-环境变量管理”中维护；这里仅作为服务器部署回退，初始值保持空。
# GitLab 默认 API 地址：仓库绑定、用户 OAuth 与快速发起 MR 使用。
PLATFORM_GITLAB_DEFAULT_API_URL=
# Gitee 企业版 API 地址：项目绑定、迭代同步和测试推送共用。
PLATFORM_GITEE_DEFAULT_API_URL=
# Gitee 企业 ID / Access Token：项目管理、迭代同步与测试推送共用。
PLATFORM_GITEE_BINDING_ENTERPRISE_ID=
PLATFORM_GITEE_BINDING_ACCESS_TOKEN=
# Gitee 测试推送默认字段：创建测试计划/用例时使用的负责人、模块和用例类型编码。
PLATFORM_GITEE_TEST_PUSH_TEST_PLAN_ASSIGNEE_ID=
PLATFORM_GITEE_TEST_PUSH_TEST_CASE_MODULE_ID=
PLATFORM_GITEE_TEST_PUSH_TEST_CASE_TYPE=
# GitLab OAuth 参数：个人中心绑定 GitLab 账号时使用。
PLATFORM_GITLAB_OAUTH_CLIENT_ID=
PLATFORM_GITLAB_OAUTH_CLIENT_SECRET=
PLATFORM_GITLAB_OAUTH_REDIRECT_URI=
# PR 评审统计 OA 参数：读取开发组、PR 和待处理缺陷时使用。
PLATFORM_PR_REVIEW_OA_BASE_URL=
PLATFORM_PR_REVIEW_DEFAULT_DEV_GROUP_NAME=
PLATFORM_PR_REVIEW_OA_USER_ID=
PLATFORM_PR_REVIEW_OA_TOKEN=

# 平台基础安全配置。
PLATFORM_TOKEN_SECRET=ai-club-demo-token-secret
PLATFORM_TOKEN_EXPIRE_HOURS=12
PLATFORM_SECURITY_SESSION_KEY_PREFIX=ai-club:login:token:
PLATFORM_SECURITY_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*,http://192.168.*:*,http://10.*:*

# Yaade 连接与代登配置。
# 除 PLATFORM_YAADE_DEFAULT_USER_PASSWORD 外，其余项可优先在环境变量管理中维护；
# DEFAULT_USER_PASSWORD 必须与 Yaade 服务端 YAADE_DEFAULT_PASSWORD 保持一致，因此应随部署环境一起维护。
PLATFORM_YAADE_BASE_URL=
PLATFORM_YAADE_ADMIN_USERNAME=
PLATFORM_YAADE_ADMIN_PASSWORD=
PLATFORM_YAADE_DEFAULT_USER_PASSWORD=
PLATFORM_YAADE_PUBLIC_COLLECTION_NAME=
PLATFORM_YAADE_PROXY_SESSION_TTL_MINUTES=

# Hermes 服务访问配置。
# Hermes API 地址 / Key / 模型名优先在环境变量管理中维护。
PLATFORM_HERMES_BASE_URL=
PLATFORM_HERMES_API_KEY=
PLATFORM_HERMES_MODEL=
PLATFORM_HERMES_TIMEOUT_SECONDS=
PLATFORM_HERMES_SESSION_PREFIX=ai-club:hermes
PLATFORM_HERMES_MAX_CONTEXT_MESSAGES=6
PLATFORM_HERMES_GROUNDING_TTL_SECONDS=86400
PLATFORM_HERMES_MCP_SHARED_TOKEN=git-ai-club-hermes-mcp-token
# Hermes 语音转写接口配置；优先在环境变量管理中维护。
PLATFORM_HERMES_SPEECH_BASE_URL=
PLATFORM_HERMES_SPEECH_API_KEY=
PLATFORM_HERMES_SPEECH_MODEL=
PLATFORM_HERMES_SPEECH_TIMEOUT_SECONDS=

# 平台内部服务通信与仓库扫描配置。
PLATFORM_INTERNAL_SERVICE_TOKEN=git-ai-club-internal-service-token
# 容器内扫描工作目录，Linux 服务器建议保持固定容器内路径。
PLATFORM_SCAN_WORKSPACE_ROOT=/scan-workspace
# 宿主机扫描目录映射路径，用于保留克隆与扫描过程临时文件。
PLATFORM_SCAN_HOST_PATH=/data/git-ai-club/scans
PLATFORM_INTERNAL_ALLOW_LOCAL_BYPASS=false
PLATFORM_BACKEND_INTERNAL_BASE_URL=http://backend:8080
PLATFORM_MINIO_ACCESS_KEY=minioadmin
PLATFORM_MINIO_SECRET_KEY=minioadmin
PLATFORM_MINIO_BUCKET=ai-club-assets

# Codex / Claude Code CLI 执行配置；如 CLI 已安装到容器 PATH，可不显式填写路径。
PLATFORM_CODEX_CLI_PATH=
PLATFORM_CODEX_MODEL_PROVIDER=
PLATFORM_CODEX_REASONING_EFFORT=low
PLATFORM_CLAUDE_CLI_PATH=
PLATFORM_CLAUDE_MODEL=

# Hermes 依赖的大模型与记忆库配置。
HERMES_LLM_BASE_URL=https://api.openai.com/v1
HERMES_LLM_API_KEY=
HERMES_LLM_PROVIDER=custom
HERMES_LLM_MODEL=gpt-4.1-mini
# 默认仅保留 Hermes 内置 memory；如需重新启用外部 Hindsight memory provider，可显式改成 hindsight。
HERMES_MEMORY_PROVIDER=
# Hindsight bank 前缀和 recall 预算供 backend 记忆链路使用，优先在环境变量管理中维护。
HERMES_HINDSIGHT_BANK_ID=
HERMES_HINDSIGHT_BUDGET=

# Hindsight 服务配置。
# backend 访问 Hindsight API 的地址和 Key，优先在环境变量管理中维护。
HINDSIGHT_API_URL=
HINDSIGHT_API_KEY=
# backend 访问 Hindsight HTTP 接口的超时时间；当 retain / 抽事实模型响应较慢时，可按需调大。
PLATFORM_HINDSIGHT_TIMEOUT_SECONDS=
HINDSIGHT_API_LLM_PROVIDER=openai
HINDSIGHT_API_LLM_BASE_URL=https://api.openai.com/v1
HINDSIGHT_API_LLM_API_KEY=
HINDSIGHT_API_LLM_MODEL=gpt-4o-mini
HINDSIGHT_API_EMBEDDINGS_PROVIDER=openai
HINDSIGHT_API_EMBEDDINGS_LOCAL_MODEL=BAAI/bge-small-en-v1.5
HINDSIGHT_API_EMBEDDINGS_OPENAI_BASE_URL=http://127.0.0.1:8000/v1
HINDSIGHT_API_EMBEDDINGS_OPENAI_API_KEY=local
HINDSIGHT_API_EMBEDDINGS_OPENAI_MODEL=Qwen/Qwen3-Embedding-4B
HINDSIGHT_API_RERANKER_PROVIDER=rrf
HINDSIGHT_API_RERANKER_LOCAL_MODEL=BAAI/bge-reranker-v2-m3
# 当前仓库默认建议先用 rrf；如果 Hindsight 镜像版本已经明确支持 litellm reranker，再切换到 litellm。
HINDSIGHT_API_RERANKER_LITELLM_API_BASE=http://127.0.0.1:4000
HINDSIGHT_API_RERANKER_LITELLM_API_KEY=
HINDSIGHT_API_RERANKER_LITELLM_MODEL=cohere/rerank-english-v3.0
# 单一 PostgreSQL 服务同时承载业务库与 Hindsight 记忆库，通过库名隔离数据。
HINDSIGHT_POSTGRES_DB=hindsight
# 推荐写成“不带密码”的连接串，把密码交给 HINDSIGHT_API_DATABASE_PASSWORD 或 POSTGRES_PASSWORD。
# 这样可以避免复杂密码在 Alembic / SQLAlchemy URL 解析时触发转义与插值问题。
HINDSIGHT_API_DATABASE_URL=
# Hindsight 专用数据库密码；留空时默认复用 POSTGRES_PASSWORD。
HINDSIGHT_API_DATABASE_PASSWORD=
HINDSIGHT_API_VECTOR_EXTENSION=pgvectorscale

# 可观测性中心一期配置。
PLATFORM_OBSERVABILITY_ENABLED=true
PLATFORM_OBSERVABILITY_INGEST_TOKEN=git-ai-club-observability-token
PLATFORM_PROJECT_LOG_COLLECT_INTERVAL_MS=30000
PLATFORM_PROJECT_LOG_RETENTION_DAYS=14
PLATFORM_PROJECT_LOG_CHUNK_BYTES=262144
PLATFORM_PROJECT_HEALTH_INTERVAL_MS=30000
PLATFORM_PROJECT_HEALTH_RETENTION_DAYS=30
PLATFORM_PROJECT_HEALTH_HTTP_CONNECT_TIMEOUT_MS=3000
PLATFORM_PROJECT_HEALTH_HTTP_READ_TIMEOUT_MS=5000

# 各服务镜像版本配置。
BACKEND_IMAGE=git-ai-club-backend:latest
FRONTEND_IMAGE=git-ai-club-frontend:latest
CODE_PROCESSING_IMAGE=git-ai-club-code-processing:latest
POSTGRES_IMAGE=timescale/timescaledb-ha:pg16
MINIO_IMAGE=minio/minio:RELEASE.2025-02-28T09-55-16Z
REDIS_IMAGE=redis:7-alpine
HERMES_IMAGE=ghcr.io/nousresearch/hermes-agent:latest
HINDSIGHT_IMAGE=ghcr.io/vectorize-io/hindsight:latest
GITNEXUS_WEB_IMAGE=git-ai-club-gitnexus-web:latest
GITNEXUS_WEB_BASE_IMAGE=ghcr.io/abhigyanpatwari/gitnexus-web:latest
WOODPECKER_IMAGE=woodpeckerci/woodpecker-server:v3
WOODPECKER_AGENT_IMAGE=woodpeckerci/woodpecker-agent:v3

# Yaade 独立部署默认端口与数据目录。
YAADE_PORT=9339
YAADE_DATA_DIR=/data/git-ai-club/yaade
YAADE_IMAGE=git-ai-club-yaade:latest
YAADE_REF=main
YAADE_ADMIN_USERNAME=admin
YAADE_DEFAULT_PASSWORD=password
YAADE_BASE_PATH=/api/yaade/proxy
