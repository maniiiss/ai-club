# 服务器部署环境变量示例，复制为 .env.server 后即可用于 docker-compose.server.yml。
APP_TZ=Asia/Shanghai

# 服务器访问入口。
# 前端默认会使用“当前访问主机名 + VITE_API_PORT”直连后端；
# 如果需要覆盖为完整地址，可直接设置 VITE_API_BASE_URL。
SERVER_HOST=192.168.110.23
FRONTEND_PORT=5173
BACKEND_PORT=8080
VITE_API_BASE_URL=
VITE_API_PORT=8080

POSTGRES_DB=ai_agent_platform
POSTGRES_USER=aiclub
POSTGRES_PASSWORD=aiclub123
POSTGRES_PORT=5432

CODE_PROCESSING_IP=127.0.0.1
CODE_PROCESSING_PORT=9000
MINIO_PORT=19000
MINIO_CONSOLE_PORT=19001
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=
HERMES_PORT=18080
HINDSIGHT_PORT=18888
HINDSIGHT_CONSOLE_PORT=19999

PLATFORM_GITLAB_DEFAULT_API_URL=http://192.168.110.138:30080/api/v4
PLATFORM_GITLAB_OAUTH_CLIENT_ID=
PLATFORM_GITLAB_OAUTH_CLIENT_SECRET=
PLATFORM_GITLAB_OAUTH_REDIRECT_URI=http://localhost:5173/profile/gitlab-callback
PLATFORM_TOKEN_SECRET=ai-club-demo-token-secret
PLATFORM_TOKEN_EXPIRE_HOURS=12
PLATFORM_SECURITY_SESSION_KEY_PREFIX=ai-club:login:token:
PLATFORM_HERMES_BASE_URL=http://localhost:18080/v1
PLATFORM_HERMES_API_KEY=
PLATFORM_HERMES_MODEL=hermes-agent
PLATFORM_HERMES_TIMEOUT_SECONDS=180
PLATFORM_HERMES_SESSION_PREFIX=ai-club:hermes
PLATFORM_HERMES_MAX_CONTEXT_MESSAGES=6
PLATFORM_HERMES_GROUNDING_TTL_SECONDS=86400
PLATFORM_HERMES_MCP_SHARED_TOKEN=git-ai-club-hermes-mcp-token
PLATFORM_INTERNAL_SERVICE_TOKEN=git-ai-club-internal-service-token
PLATFORM_INTERNAL_ALLOW_LOCAL_BYPASS=false
PLATFORM_BACKEND_INTERNAL_BASE_URL=http://backend:8080
PLATFORM_MINIO_ACCESS_KEY=minioadmin
PLATFORM_MINIO_SECRET_KEY=minioadmin
PLATFORM_MINIO_BUCKET=ai-club-assets

HERMES_LLM_BASE_URL=https://api.openai.com/v1
HERMES_LLM_API_KEY=
HERMES_LLM_PROVIDER=custom
HERMES_LLM_MODEL=gpt-4.1-mini
HERMES_HINDSIGHT_BANK_ID=git-ai-club
HERMES_HINDSIGHT_BUDGET=mid

HINDSIGHT_API_KEY=
HINDSIGHT_API_LLM_PROVIDER=openai
HINDSIGHT_API_LLM_BASE_URL=https://api.openai.com/v1
HINDSIGHT_API_LLM_API_KEY=
HINDSIGHT_API_LLM_MODEL=gpt-4o-mini
HINDSIGHT_API_EMBEDDINGS_PROVIDER=local

BACKEND_IMAGE=git-ai-club-backend:latest
FRONTEND_IMAGE=git-ai-club-frontend:latest
CODE_PROCESSING_IMAGE=git-ai-club-code-processing:latest
POSTGRES_IMAGE=postgres:16
MINIO_IMAGE=minio/minio:RELEASE.2025-02-28T09-55-16Z
REDIS_IMAGE=redis:7-alpine
HERMES_IMAGE=ghcr.io/nousresearch/hermes-agent:latest
HINDSIGHT_IMAGE=ghcr.io/vectorize-io/hindsight:latest
