# 服务器部署环境变量示例，复制为 .env.server 后即可用于 docker-compose.server.yml。
# 容器内默认时区，建议与服务器所在地保持一致。
APP_TZ=Asia/Shanghai

# 服务器访问入口。
# 这里的 SERVER_HOST 只提供给浏览器、回调地址和宿主机暴露端口使用；
# compose 内部服务之间会固定使用 code-processing / hindsight / postgres 等服务名互联。
# 前端默认会使用“当前访问主机名 + VITE_API_PORT”直连后端；
# 如果需要覆盖为完整地址，可直接设置 VITE_API_BASE_URL。
SERVER_HOST=192.168.110.23
FRONTEND_PORT=5173
BACKEND_PORT=8080
VITE_API_BASE_URL=
VITE_API_PORT=8080

# PostgreSQL 数据库配置。
POSTGRES_DB=ai_agent_platform
POSTGRES_USER=aiclub
POSTGRES_PASSWORD=aiclub123
POSTGRES_PORT=5432
POSTGRES_DATA_DIR=/data/git-ai-club/postgres

# 基础服务端口配置。
CODE_PROCESSING_IP=127.0.0.1
CODE_PROCESSING_PORT=9000
MINIO_PORT=19000
MINIO_CONSOLE_PORT=19001
MINIO_DATA_DIR=/data/git-ai-club/minio
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=
REDIS_DATA_DIR=/data/git-ai-club/redis
HERMES_PORT=18080
HERMES_DATA_DIR=/data/git-ai-club/hermes
HINDSIGHT_PORT=18888
HINDSIGHT_CONSOLE_PORT=19999

# GitLab 与平台基础安全配置。
# Gitee 企业 ID / Access Token 现在可由系统设置-环境变量管理实时覆盖；
# 这里的值只作为兼容回退，未在后台配置时才会被读取。
PLATFORM_GITLAB_DEFAULT_API_URL=http://192.168.110.138:30080/api/v4
PLATFORM_GITEE_BINDING_ENTERPRISE_ID=
PLATFORM_GITEE_BINDING_ACCESS_TOKEN=
PLATFORM_GITLAB_OAUTH_CLIENT_ID=
PLATFORM_GITLAB_OAUTH_CLIENT_SECRET=
PLATFORM_GITLAB_OAUTH_REDIRECT_URI=http://localhost:5173/profile/gitlab-callback
PLATFORM_TOKEN_SECRET=ai-club-demo-token-secret
PLATFORM_TOKEN_EXPIRE_HOURS=12
PLATFORM_SECURITY_SESSION_KEY_PREFIX=ai-club:login:token:
PLATFORM_YAADE_BASE_URL=http://127.0.0.1:9339/api/yaade/proxy
PLATFORM_YAADE_ADMIN_USERNAME=admin
PLATFORM_YAADE_ADMIN_PASSWORD=password
PLATFORM_YAADE_DEFAULT_USER_PASSWORD=password
PLATFORM_YAADE_PUBLIC_COLLECTION_NAME=未关联项目
PLATFORM_YAADE_PROXY_SESSION_TTL_MINUTES=120

# Hermes 服务访问配置。
PLATFORM_HERMES_BASE_URL=http://localhost:18080/v1
PLATFORM_HERMES_API_KEY=
PLATFORM_HERMES_MODEL=hermes-agent
PLATFORM_HERMES_TIMEOUT_SECONDS=180
PLATFORM_HERMES_SESSION_PREFIX=ai-club:hermes
PLATFORM_HERMES_MAX_CONTEXT_MESSAGES=6
PLATFORM_HERMES_GROUNDING_TTL_SECONDS=86400
PLATFORM_HERMES_MCP_SHARED_TOKEN=git-ai-club-hermes-mcp-token
PLATFORM_HERMES_SPEECH_BASE_URL=https://api.openai.com/v1
PLATFORM_HERMES_SPEECH_API_KEY=
PLATFORM_HERMES_SPEECH_MODEL=gpt-4o-mini-transcribe
PLATFORM_HERMES_SPEECH_TIMEOUT_SECONDS=60

# 平台内部服务通信与仓库扫描配置。
PLATFORM_INTERNAL_SERVICE_TOKEN=git-ai-club-internal-service-token
# 容器内扫描工作目录，Linux 服务器建议保持固定容器内路径。
PLATFORM_SCAN_WORKSPACE_ROOT=/scan-workspace
# 宿主机扫描目录映射路径，用于保留克隆与扫描过程临时文件。
PLATFORM_SCAN_HOST_PATH=/data/git-ai-club/scans
PLATFORM_INTERNAL_ALLOW_LOCAL_BYPASS=false
PLATFORM_BACKEND_INTERNAL_BASE_URL=http://backend:8080
PLATFORM_MINIO_ACCESS_KEY=minioadmin
PLATFORM_MINIO_SECRET_KEY=minioadmin
PLATFORM_MINIO_BUCKET=ai-club-assets

# Codex / Claude Code CLI 执行配置；如 CLI 已安装到容器 PATH，可不显式填写路径。
PLATFORM_CODEX_CLI_PATH=
PLATFORM_CODEX_MODEL_PROVIDER=
PLATFORM_CODEX_REASONING_EFFORT=low
PLATFORM_CLAUDE_CLI_PATH=
PLATFORM_CLAUDE_MODEL=

# Hermes 依赖的大模型与记忆库配置。
HERMES_LLM_BASE_URL=https://api.openai.com/v1
HERMES_LLM_API_KEY=
HERMES_LLM_PROVIDER=custom
HERMES_LLM_MODEL=gpt-4.1-mini
HERMES_HINDSIGHT_BANK_ID=git-ai-club
HERMES_HINDSIGHT_BUDGET=mid

# Hindsight 服务配置。
HINDSIGHT_API_KEY=
# backend 访问 Hindsight HTTP 接口的超时时间；当 retain / 抽事实模型响应较慢时，可按需调大。
PLATFORM_HINDSIGHT_TIMEOUT_SECONDS=30
HINDSIGHT_API_LLM_PROVIDER=openai
HINDSIGHT_API_LLM_BASE_URL=https://api.openai.com/v1
HINDSIGHT_API_LLM_API_KEY=
HINDSIGHT_API_LLM_MODEL=gpt-4o-mini
HINDSIGHT_API_EMBEDDINGS_PROVIDER=openai
HINDSIGHT_API_EMBEDDINGS_LOCAL_MODEL=BAAI/bge-small-en-v1.5
HINDSIGHT_API_EMBEDDINGS_OPENAI_BASE_URL=http://127.0.0.1:8000/v1
HINDSIGHT_API_EMBEDDINGS_OPENAI_API_KEY=local
HINDSIGHT_API_EMBEDDINGS_OPENAI_MODEL=Qwen/Qwen3-Embedding-4B
HINDSIGHT_API_RERANKER_PROVIDER=rrf
HINDSIGHT_API_RERANKER_LOCAL_MODEL=BAAI/bge-reranker-v2-m3
# 当前仓库默认建议先用 rrf；如果 Hindsight 镜像版本已经明确支持 litellm reranker，再切换到 litellm。
HINDSIGHT_API_RERANKER_LITELLM_API_BASE=http://127.0.0.1:4000
HINDSIGHT_API_RERANKER_LITELLM_API_KEY=
HINDSIGHT_API_RERANKER_LITELLM_MODEL=cohere/rerank-english-v3.0
# 单一 PostgreSQL 服务同时承载业务库与 Hindsight 记忆库，通过库名隔离数据。
HINDSIGHT_POSTGRES_DB=hindsight
HINDSIGHT_API_VECTOR_EXTENSION=pgvectorscale

# 各服务镜像版本配置。
BACKEND_IMAGE=git-ai-club-backend:latest
FRONTEND_IMAGE=git-ai-club-frontend:latest
CODE_PROCESSING_IMAGE=git-ai-club-code-processing:latest
POSTGRES_IMAGE=timescale/timescaledb-ha:pg16
MINIO_IMAGE=minio/minio:RELEASE.2025-02-28T09-55-16Z
REDIS_IMAGE=redis:7-alpine
HERMES_IMAGE=ghcr.io/nousresearch/hermes-agent:latest
HINDSIGHT_IMAGE=ghcr.io/vectorize-io/hindsight:latest

# Yaade 独立部署默认端口与数据目录。
YAADE_PORT=9339
YAADE_DATA_DIR=/data/git-ai-club/yaade
YAADE_IMAGE=git-ai-club-yaade:latest
YAADE_REF=main
YAADE_ADMIN_USERNAME=admin
YAADE_DEFAULT_PASSWORD=password
YAADE_BASE_PATH=/api/yaade/proxy
